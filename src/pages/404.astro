---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — ไม่เจอหน้านี้ค่ะ 🐆 · บ๊องแบ๊ง"
  description="ไม่พบหน้าที่ขอค่ะ — ลองกลับหน้าแรกหรือดูรายการบล็อกและหนังสือได้เลย"
>
  <div style="
    max-width: 600px;
    margin: 0 auto;
    padding: 6rem 1.5rem 8rem;
    text-align: center;
  ">
    <div style="font-size: 5rem; margin-bottom: 1.5rem;" aria-hidden="true">🐆</div>

    <h1 style="
      font-size: clamp(2rem, 6vw, 3.5rem);
      font-weight: 800;
      color: var(--text-primary);
      margin: 0 0 1rem;
      line-height: 1.1;
    ">
      ไม่เจอหน้านี้ค่ะ
    </h1>

    <p style="
      color: var(--text-secondary);
      font-size: var(--text-lg);
      line-height: 1.7;
      margin: 0 0 0.5rem;
    ">
      บ๊องวิ่งหาทั่วทุ่งกว้างแล้ว แต่ไม่เจอหน้าที่ต้องการค่ะ
    </p>
    <p style="color: var(--text-muted); font-size: var(--text-sm); margin: 0 0 3rem;" lang="en">
      404 — Page not found
    </p>

    <!-- Action links -->
    <div style="display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center;">
      <a
        href="/"
        class="btn-primary"
        style="text-decoration: none;"
      >
        🏠 กลับหน้าแรก
      </a>
      <a
        href="/books"
        class="btn-outline"
        style="text-decoration: none;"
      >
        📚 ดูหนังสือ
      </a>
      <a
        href="/blog"
        class="btn-outline"
        style="text-decoration: none;"
      >
        ✍️ บล็อก
      </a>
    </div>
  </div>
</BaseLayout>
