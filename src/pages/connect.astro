---
import BaseLayout from '../layouts/BaseLayout.astro';
import WalletConnect from '../components/WalletConnect';
---

<BaseLayout
  title="Connect — Bongbaeng's Savanna"
  description="Connect your wallet to Bongbaeng's Savanna (demo stub)"
>
  <div style="max-width: 640px; margin: 0 auto; padding: 4rem 1.5rem; text-align: center;">

    <h1 style="
      font-size: var(--text-4xl);
      font-weight: 800;
      color: var(--text-primary);
      margin: 0 0 0.5rem;
      letter-spacing: -0.01em;
    ">
      🔌 Connect
    </h1>
    <!-- text-secondary ≥11:1 all themes ✅ -->
    <p style="color: var(--text-secondary); margin: 0 0 0.5rem; line-height: 1.6;">
      เชื่อมต่อ wallet เพื่อพิสูจน์ตัวตนค่ะ
    </p>
    <!-- text-muted raised ≥7:1 all themes ✅ -->
    <p style="color: var(--text-muted); font-size: var(--text-sm); margin: 0 0 3rem; line-height: 1.6;" lang="en">
      Connect your Ethereum wallet to verify your identity (demo stub — no real transactions)
    </p>

    <!-- React island -->
    <WalletConnect client:load />

    <!-- Info box -->
    <div class="card" style="margin-top: 3rem; text-align: left;">
      <h3 style="
        font-size: var(--text-base);
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 0.75rem;
      ">
        ℹ️ เกี่ยวกับหน้านี้
      </h3>
      <ul style="color: var(--text-secondary); font-size: var(--text-sm); line-height: 1.85; padding-left: 1.25rem; margin: 0;">
        <li>นี่คือ <strong>demo stub</strong> — ไม่มี Web3 SDK จริง ไม่ต้องมี wallet</li>
        <li>ไม่มี private key ในโค้ด — ปลอดภัยทั้งหมด</li>
        <li>state ผ่าน <code style="
          background-color: var(--bg-secondary);
          color: var(--text-primary);
          padding: 0.125rem 0.375rem;
          border-radius: var(--radius-sm);
          font-size: 0.85em;
          border: 1px solid var(--border);
          font-family: var(--font-mono);
        ">nanostores</code> — sync ข้าม island ค่ะ</li>
        <li lang="en">Real wallet integration (viem + EIP-1193) will be added in a future workshop</li>
      </ul>
    </div>

  </div>
</BaseLayout>
