---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateStr = post.data.date.toLocaleDateString('th-TH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const isoDate = post.data.date.toISOString();
const pageDescription = post.data.description ?? post.data.title;
const siteBase = 'https://bongbaeng.buildwithoracle.com';
const postUrl = `${siteBase}/blog/${post.id}/`;

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      '@id': `${postUrl}#blogposting`,
      headline: post.data.title,
      alternativeHeadline: post.data.titleEn,
      description: pageDescription,
      datePublished: isoDate,
      dateModified: isoDate,
      url: postUrl,
      inLanguage: 'th',
      author: {
        '@type': 'Person',
        '@id': `${siteBase}/#person`,
        name: 'บ๊องแบ๊ง',
        alternateName: 'Bongbaeng Oracle',
        url: `${siteBase}/about/`,
      },
      publisher: {
        '@id': `${siteBase}/#person`,
      },
      isPartOf: {
        '@id': `${siteBase}/#website`,
      },
      ...(post.data.repo
        ? { sameAs: [`https://github.com/${post.data.repo}`] }
        : {}),
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${postUrl}#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'หน้าแรก',
          item: `${siteBase}/`,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'บล็อก',
          item: `${siteBase}/blog/`,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: post.data.title,
          item: postUrl,
        },
      ],
    },
  ],
};
---

<BaseLayout
  title={`${post.data.title} — บ๊องแบ๊ง`}
  description={pageDescription}
  ogType="article"
  articleDate={isoDate}
>

  <!-- JSON-LD: BlogPosting + BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />

  <!-- Outer wrapper: landmark, not article — avoids nested article semantics issue -->
  <div style="max-width: 780px; margin: 0 auto; padding: 3rem 1.5rem;">
    <!-- Back link — nav-link class provides focus-visible -->
    <a href={`${import.meta.env.BASE_URL.replace(/\/$/,'')}/blog`} class="nav-link" style="
      font-size: var(--text-sm);
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      margin-bottom: 2rem;
    ">
      ← กลับไปบล็อก
    </a>

    <!--
      Safari Reader detection requires:
      1. <article> element wrapping post content
      2. <h1> inside article (not just header)
      3. <time datetime="..."> near the top
      4. Multiple <p> paragraphs in the body
      5. meta description present (inherited from BaseLayout)
    -->
    <article
      itemscope
      itemtype="https://schema.org/BlogPosting"
      style="display: contents;"
    >
      <!-- Hidden machine-readable meta for schema.org -->
      <meta itemprop="datePublished" content={isoDate} />
      <meta itemprop="author" content="บ๊องแบ๊ง Oracle" />
      <meta itemprop="description" content={pageDescription} />

      <!-- Header — semantic article header -->
      <header style="margin-bottom: 2.5rem;">
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; flex-wrap: wrap;">
          <!-- Workshop badge: white on red → 4.76:1 ✅ -->
          <span class="badge-workshop">WORKSHOP {post.data.workshop}</span>

          <!-- Safari Reader picks up <time datetime> near the article top -->
          <time
            itemprop="datePublished"
            datetime={isoDate}
            style="color: var(--text-muted); font-size: var(--text-sm);"
          >
            {dateStr}
          </time>
        </div>

        <!-- <h1> inside <article> is required for Safari Reader eligibility -->
        <h1
          itemprop="headline"
          style="
            font-size: clamp(1.75rem, 5vw, 2.5rem);
            font-weight: 800;
            color: var(--text-primary);
            line-height: 1.2;
            margin: 0 0 0.5rem;
            letter-spacing: -0.01em;
          "
        >
          {post.data.title}
        </h1>

        <!-- EN title: text-muted raised ≥7:1 ✅ -->
        <p style="color: var(--text-muted); font-size: var(--text-sm); margin: 0;" lang="en">
          {post.data.titleEn}
        </p>

      </header>

      <!-- Savanna divider -->
      <div class="savanna-divider" aria-hidden="true" style="margin-bottom: 2.5rem;"></div>

      <!-- Article body — Safari Reader needs .prose content within <article> -->
      <div class="prose" itemprop="articleBody">
        <Content />
      </div>

      <!-- Footer nav (on-site first, off-site last — Task 1) -->
      <footer style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border); display: flex; flex-direction: column; gap: 1rem;">
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/,'')}/blog`} class="nav-link" style="color: var(--accent); font-weight: 600;">
          ← กลับรายการบล็อก
        </a>
        {post.data.repo && (
          <div style="
            padding: 0.75rem 1rem;
            background-color: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            font-size: var(--text-sm);
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex-wrap: wrap;
          ">
            <span style="color: var(--text-muted);">📦 Source code:</span>
            <a
              href={`https://github.com/${post.data.repo}`}
              target="_blank"
              rel="noopener noreferrer"
              class="repo-link"
              style="text-decoration: none; font-weight: 500;"
            >
              {post.data.repo}
            </a>
          </div>
        )}
      </footer>
    </article>
  </div>
</BaseLayout>
